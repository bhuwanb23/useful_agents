# Local System Configuration (NO DOCKER / NO REDIS)

# Database
# Note: SQLite will be created as 'dev.db' in the project root
DATABASE_URL="file:./dev.db"

# AI Configuration (Native Ollama)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_DEFAULT_MODEL="gemma2:9b"

# ChromaDB Configuration (Local Storage)
# Chroma will save data to './chroma_db' folder
CHROMA_URL="http://localhost:8000"

# GitHub
GITHUB_TOKEN="ghp_your_token"
GITHUB_WEBHOOK_SECRET="local_development_secret"

# API Settings
PORT=3001
NODE_ENV="development"
LOG_LEVEL="info"
