# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/github_agent?schema=public"

# Redis Configuration (for BullMQ task queue)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# Ollama Configuration
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_SERVERS="http://localhost:11434,http://localhost:11435,http://localhost:11436"
OLLAMA_DEFAULT_MODEL="gemma2:9b"
OLLAMA_MAX_CONCURRENT=1

# ChromaDB Configuration
CHROMA_URL="http://localhost:8000"
EMBED_MODEL="nomic-embed-text"

# GitHub Configuration
GITHUB_WEBHOOK_SECRET="your-webhook-secret-here"

# API Server Configuration
PORT=3001
NODE_ENV="development"

# Security
JWT_SECRET="your-jwt-secret-here"
API_KEY="your-api-key-here"

# Logging
LOG_LEVEL="info"
