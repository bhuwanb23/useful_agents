// Prisma Schema for GitHub Agent System
// PostgreSQL Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== CORE ENTITIES =====

model Repository {
  id            String   @id @default(uuid())
  name          String
  owner         String
  url           String   @unique
  githubToken   String   // Encrypted in production
  isActive      Boolean  @default(true)
  
  // Metadata
  defaultBranch String   @default("main")
  language      String?
  description   String?
  
  // Monitoring
  lastSyncedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  issues        Issue[]
  tasks         Task[]
  pullRequests  PullRequest[]
  
  @@index([owner, name])
  @@index([isActive])
}

model Issue {
  id              String   @id @default(uuid())
  githubIssueId   Int
  number          Int
  title           String
  body            String?
  state           String   // open, closed, in_progress
  
  // Classification
  issueType       String   // bug, feature, security, documentation, test
  priority        String   @default("medium") // low, medium, high, critical
  complexity      String?  // simple, moderate, complex
  
  // Assignment
  assignedAgent   String?
  
  // Metadata
  labels          String[] // JSON array of label names
  githubUrl       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  closedAt        DateTime?
  
  // Relations
  repositoryId    String
  repository      Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  tasks           Task[]
  pullRequests    PullRequest[]
  
  @@unique([repositoryId, githubIssueId])
  @@index([state])
  @@index([issueType])
  @@index([priority])
}

model Task {
  id              String   @id @default(uuid())
  
  // Task Definition
  name            String
  type            String   // analyze, fix, review, security_scan, test, document
  status          String   @default("pending") // pending, queued, running, completed, failed, retrying
  priority        Int      @default(50) // 0-100, higher = more urgent
  
  // Execution
  agentType       String   // analyzer, fixer, reviewer, security, tester, docs
  attempt         Int      @default(1)
  maxRetries      Int      @default(3)
  
  // Input/Output
  input           Json     // Task-specific input data
  output          Json?    // Task result data
  error           String?  // Error message if failed
  
  // Timing
  queuedAt        DateTime @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  duration        Int?     // Duration in milliseconds
  
  // Relations
  repositoryId    String
  repository      Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  issueId         String?
  issue           Issue?   @relation(fields: [issueId], references: [id], onDelete: SetNull)
  
  executions      Execution[]
  dependencies    TaskDependency[] @relation("DependentTask")
  dependents      TaskDependency[] @relation("BlockedTask")
  
  @@index([status])
  @@index([agentType])
  @@index([queuedAt])
  @@index([repositoryId, status])
}

// Task dependency graph (e.g., Fix must complete before Review)
model TaskDependency {
  id              String   @id @default(uuid())
  
  dependentTaskId String   // Task that must complete first
  dependentTask   Task     @relation("DependentTask", fields: [dependentTaskId], references: [id], onDelete: Cascade)
  
  blockedTaskId   String   // Task waiting on the dependent
  blockedTask     Task     @relation("BlockedTask", fields: [blockedTaskId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  
  @@unique([dependentTaskId, blockedTaskId])
  @@index([blockedTaskId])
}

model Execution {
  id              String   @id @default(uuid())
  
  // Agent Info
  agentType       String   // analyzer, fixer, reviewer, security, tester, docs, manager
  agentVersion    String   @default("1.0.0")
  
  // Execution State
  status          String   @default("running") // running, completed, failed
  stage           String?  // Current stage: analyzing, planning, executing, reviewing
  progress        Int      @default(0) // 0-100 percentage
  
  // LLM Details
  modelName       String?  // e.g., "llama3:70b"
  promptVersion   String?  // e.g., "fixer_v2.txt"
  tokensUsed      Int?
  
  // Timing
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  duration        Int?     // Milliseconds
  
  // Relations
  taskId          String
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  logs            AgentLog[]
  
  @@index([taskId])
  @@index([status])
  @@index([agentType])
}

model AgentLog {
  id              String   @id @default(uuid())
  
  // Log Entry
  level           String   // debug, info, warn, error, thought
  message         String
  timestamp       DateTime @default(now())
  
  // Context
  metadata        Json?    // Additional structured data
  
  // Relations
  executionId     String
  execution       Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  
  @@index([executionId, timestamp])
  @@index([level])
}

model PullRequest {
  id              String   @id @default(uuid())
  githubPrId      Int
  number          Int
  title           String
  body            String?
  state           String   // open, closed, merged
  
  // PR Details
  sourceBranch    String
  targetBranch    String   @default("main")
  githubUrl       String
  
  // Files Changed
  filesChanged    String[] // Array of file paths
  additions       Int      @default(0)
  deletions       Int      @default(0)
  
  // Status
  mergeable       Boolean  @default(true)
  merged          Boolean  @default(false)
  mergedAt        DateTime?
  
  // Human Approval
  requiresApproval Boolean @default(true)
  approvedBy      String?
  approvedAt      DateTime?
  
  // Metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  repositoryId    String
  repository      Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  issueId         String?
  issue           Issue?   @relation(fields: [issueId], references: [id], onDelete: SetNull)
  
  @@unique([repositoryId, githubPrId])
  @@index([state])
}

// ===== AGENT INTELLIGENCE =====

// Vector embeddings for RAG (Code search)
model CodeEmbedding {
  id              String   @id @default(uuid())
  
  // Source Code
  filePath        String
  startLine       Int
  endLine         Int
  codeSnippet     String   @db.Text
  language        String?
  
  // Embedding Vector (stored as JSON array for PostgreSQL)
  // In production, use pgvector extension
  embedding       Json     // Float array [0.1, 0.2, ..., 0.768]
  embeddingModel  String   @default("nomic-embed-text")
  
  // Metadata
  purpose         String?  // function, class, import, config
  symbols         String[] // Function/class names found
  
  // Relations
  repositoryId    String
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([repositoryId, filePath])
  @@index([repositoryId])
}

// Prompt Version Control
model Prompt {
  id              String   @id @default(uuid())
  
  // Prompt Identity
  name            String   // e.g., "fixer", "reviewer", "analyzer"
  version         String   // e.g., "v1", "v2", "v2.1"
  
  // Content
  systemPrompt    String   @db.Text
  userPrompt      String   @db.Text
  
  // Configuration
  temperature     Float    @default(0.7)
  maxTokens       Int      @default(2000)
  topP            Float    @default(0.9)
  
  // Status
  isActive        Boolean  @default(false)
  isDeprecated    Boolean  @default(false)
  
  // Metadata
  description     String?
  author          String?
  changeLog       String?  @db.Text
  
  createdAt       DateTime @default(now())
  
  @@unique([name, version])
  @@index([name, isActive])
}

// System Configuration
model SystemConfig {
  id              String   @id @default(uuid())
  key             String   @unique
  value           Json
  description     String?
  
  updatedAt       DateTime @updatedAt
  
  @@index([key])
}

// Ollama Server Pool (for load balancing)
model OllamaServer {
  id              String   @id @default(uuid())
  
  // Server Info
  url             String   @unique // e.g., "http://ollama-1:11434"
  name            String?
  
  // Status
  isActive        Boolean  @default(true)
  isHealthy       Boolean  @default(true)
  lastHealthCheck DateTime?
  
  // Metrics
  activeJobs      Int      @default(0)
  totalJobs       Int      @default(0)
  avgResponseTime Float?   // Milliseconds
  
  // Capacity
  maxConcurrent   Int      @default(1)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([isActive, isHealthy])
}
